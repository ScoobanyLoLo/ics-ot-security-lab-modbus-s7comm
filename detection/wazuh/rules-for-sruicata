<group name="suricata">
  <rule id="200100" level="0">
    <decoded_as>json</decoded_as>
    <field name="event_type">(\.+)</field>
    <description>Suricata Alerts </description>
  </rule>
  <rule id="200200" level="9">
    <if_sid>200100</if_sid>
    <field name="signature">ET SCAN NMAP</field>
    <description>Suricata: Port scan activity observed from $(srcip) to $(dstport)</description>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>
 <rule id="200250" level="12">
