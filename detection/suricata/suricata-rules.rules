alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET SCAN NMAP -sS window 1024"; fragbits:!D; dsize:0; flags:S,12; ack:0; window:1024; threshold: type both, track by_dst, count 1, seconds 60; classtype:attempted-recon; sid:2009582; rev:3; metadata:created_at 2010_07_30, confidence Low, signature_severity Informational, updated_at 2019_07_26;)
alert tcp $MODBUS_CLIENT any -> $MODBUS_SERVER 502 (msg:"Read Multiple Registers MODBUS"; app-layer-protocol:modbus; modbus: access read holding; sid:4004444; rev:1;)
alert tcp $MODBUS_CLIENT any -> $MODBUS_SERVER 502 (msg:"Write Multiple Registers MODBUS"; app-layer-protocol:modbus; modbus: access write holding; sid:4003333; rev:1;)
alert tcp !$MODBUS_CLIENT any -> $MODBUS_SERVER 502 (msg:"Unauthorized Modbus Write Request"; app-layer-protocol:modbus; modbus: access write holding; sid:4005555; rev:1;)
alert tcp !$MODBUS_CLIENT any -> $MODBUS_SERVER 502 (msg:"Unauthorized Modbus Read Request"; app-layer-protocol:modbus; modbus: access read holding; sid:4006666; rev:1;)
dos-detect.rules alert tcp any any -> $HOME_NET 102 (msg:"DOS SYN flood TCP/102"; flags:S; flow:to_server,stateless; detection_filter:track by_src, count 100, seconds 3; classtype:attempted-dos; sid:4000502; rev:1;)
s7comm.rules alert tcp any any -> $HOME_NET 102 (msg:"s7comm diagnostic session attempt TCP/102"; flow:to_server,established; content:"|03 00|"; depth:2; content:"|02 F0 80|"; distance:0; within:16; content:"|32|"; distance:0; within:32; threshold:type limit, track by_src, count 1, seconds 60; classtype:attempted-recon; sid:4000902; rev:1;)
